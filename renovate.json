{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "ignoreDeps": ["cryptography"],
      "lockFileMaintenance": {
        "enabled": true
    },
  "packageRules": [
    {
      "groupName": "all dependencies",
      "matchPackageNames": [
        "*"
      ]
    }
  ]
}
